package Practicals_ds;

public class linear_search {
	
	public static int linearSearch(int[] arr,int value) {
		int n = arr.length;
		
		for(int i = 0; i<n; i++) {
			if(arr[i]==value) {
				return i;
			}
		}
		return -1;
	}

	public static void main(String[] args) {
		
		int[] arr = {5,54,78,32,87,58};
		int value_to_find = 54;
		
		int result = linearSearch(arr, value_to_find);
		
		if(result != -1) {
			System.out.println("value is been found at index: "+result+1);
		}
		else {
			System.out.println("value is not been found in the given array");
		}

	}

}
