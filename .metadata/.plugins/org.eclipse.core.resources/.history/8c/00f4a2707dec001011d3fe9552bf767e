package Practicals_ds;

import java.util.Arrays;

public class bubble_sort {

	public static void bubbleSort(int arr[]) {
		int n = arr.length;
		
		for(int i=0;i<n-1;i++) {
			
			for(int j=0;j<n-i-1;j++) {
				
				if(arr[j]>arr[i]) {
					int temp = arr[j];
					arr[j] = arr[j+1];
					arr[j+1]= temp;
				}
			}
		}
	}
	
	public static void main(String[] args) {
		int[] data = {64, 34, 25, 12, 22, 11, 90};
		
		//Arrays.toString(data)-->converts the array data in a string format
		System.out.println("unsorted arrays: "+ Arrays.toString(data));
		
		bubbleSort(data);
		
		System.out.println("Sorted Arrays in Ascending order: "+ Arrays.toString(data));
		
	}
}
